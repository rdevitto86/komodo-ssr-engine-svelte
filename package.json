{
  "name": "komodo-ssr-engine-svelte",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "start": "bun run build/index.js",
    "build": "vite build",
    "preview": "vite preview",
    "bootstrap": "bun install && bun run build",
    "up": "bun update --latest",
    "fresh": "bun run clean && bun install",
    "clean": "rm -rf node_modules bun.lock",
    "gen:types": "bun run scripts/gen-types.ts",
    "test": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-cloudfront": "^3.1064.0",
    "@aws-sdk/client-s3": "^3.1064.0",
    "@komodo-forge-sdk/typescript": "github:rdevitto86/komodo-forge-sdk-ts",
    "better-sqlite3": "^12.10.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.64.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "^1.3.14",
    "svelte": "^5.56.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "type": "module"
}